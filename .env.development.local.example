# ─── Local dev secrets (gitignored — fill in your own values) ───

# Database (Neon dev branch)
DATABASE_URL=

# Better Auth
BETTER_AUTH_SECRET=
# External APIs
OPENAI_API_KEY=
BIBLE_API_KEY=

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=anchor-dev
R2_PUBLIC_URL=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash (local dev server defaults from `npx @upstash/qstash-cli dev`)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
