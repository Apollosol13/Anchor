{
  "name": "anchor-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "turbo run start stripe tinybird:dev test:watch",
    "dev:device": "turbo run ios:device:tunnel stripe tinybird:dev test:watch qstash:local",
    "dev:mprocs": "mprocs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "ios:device:tunnel": "expo start --dev-client --tunnel",
    "web": "expo start --web",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lnt": "oxlint --fix",
    "lnt:check": "oxlint",
    "typecheck": "tsc --noEmit",
    "sanity": "turbo run typecheck lnt:check fmt:check test tinybird:test",
    "build:device:create": "eas device:create",
    "build:ios:preview": "eas build --profile preview --platform ios",
    "stripe": "stripe listen --forward-to localhost:8081/api/auth/stripe/webhook",
    "db:seed": "bunx tsx server/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "qstash:local": "npx @upstash/qstash-cli dev",
    "test": "bun test",
    "test:watch": "bun test --watch || true",
    "tinybird:dev": "tinybird dev --local",
    "tinybird:build": "tinybird build",
    "tinybird:deploy": "tinybird deploy",
    "tinybird:preview": "tinybird preview",
    "tinybird:mock": "cd tinybird && for f in *.datasource; do [ -f \"$f\" ] || continue; name=$(basename \"$f\" .datasource); tb mock \"$name\" --rows 50; done",
    "tinybird:test": "cd tinybird && tb test run",
    "tinybird:test:pull": "cd tinybird && tinybird pull",
    "tinybird:test:delete-rows": "cd tinybird && for f in *.datasource; do [ -f \"$f\" ] || continue; name=$(basename \"$f\" .datasource); tb datasource delete \"$name\" --sql-condition \"timestamp IS NOT NULL\" --yes --wait; done",
    "tinybird:test:delete-raw-files": "cd tinybird && rm -rf fixtures *.datasource *.pipe",
    "tinybird:test:create": "cd tinybird && for f in *.pipe; do [ -f \"$f\" ] || continue; tb test create \"$f\"; done",
    "tinybird:test:reset": "turbo run tinybird:test:delete-rows tinybird:test:delete-raw-files tinybird:test:pull tinybird:mock tinybird:test:create",
    "check:ccusage": "bunx ccusage",
    "web:export": "bunx expo export -p web --clear",
    "web:export:delete-maps": "find dist -name '*.map' -type f -delete",
    "web:deploy:prod": "npx eas-cli@latest deploy --prod"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@better-auth/expo": "^1.5.5",
    "@expo/vector-icons": "^14.0.0",
    "@neondatabase/serverless": "^1.0.2",
    "@react-navigation/native": "^6.1.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@upstash/workflow": "^1.1.1",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.45.1",
    "expo": "~54.0.0",
    "expo-asset": "~11.0.0",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.0",
    "expo-font": "~13.0.0",
    "expo-image-picker": "~17.0.0",
    "expo-linear-gradient": "~15.0.0",
    "expo-linking": "~8.0.11",
    "expo-modules-autolinking": "~3.0.0",
    "expo-modules-core": "~3.0.0",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.8",
    "expo-server-sdk": "^6.1.0",
    "expo-sharing": "~14.0.0",
    "expo-status-bar": "~3.0.0",
    "openai": "^6.29.0",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "~15.9.0",
    "react-native-view-shot": "^3.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.0",
    "drizzle-kit": "^0.31.9",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "bun@1.3.9"
}
